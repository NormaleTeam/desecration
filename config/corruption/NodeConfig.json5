{
	/* 每个中心阶段升级所需点数
	     索引 N = 从阶段 N 升到 N+1 所需的点数
	     数组长度决定节点可达最大阶段数（超出后不再升阶）
	*/
	"phaseThresholds": [
		100.0,
		250.0,
		500.0,
		1000.0,
		2000.0,
		3500.0,
		5500.0,
		8000.0,
		11000.0,
		15000.0
	],
	// 群系开始从中心向外扩散时节点中心阶段需达到的阈值
	"biomeDiffusionPhase": 5,
	// 每个维度允许存在的最大节点数量（上限 12）
	"maxNodesPerLevel": 12,
	// 世界初始化时，初始节点中心距出生点的最大距离（方块数，XZ 平面圆形范围）
	"spawnNodeRadius": 1000,
	// 初始节点的影响半径（方块数）
	"initialRadius": 120.0,
	// 初始节点的中心强度
	"initialIntensity": 0.800000011920929,
	// 初始节点的初始中心阶段
	"initialCenterPhase": 1,
	// 节点叠加后阶段总值上限（-1 表示无上限）
	"maxStackedPhase": -1,
	// 节点叠加后强度总值上限（-1 表示无上限）
	"maxStackedIntensity": -1.0,
	// 节点半径每游戏刻自然增长量（0 = 不自动增长，由其他机制控制）
	"radiusGrowthPerTick": 0.0,
	// 节点强度每游戏刻自然增长量（0 = 不自动增长）
	"intensityGrowthPerTick": 0.0,
	// 节点半径最大值上限（-1 表示无上限）
	"maxRadius": -1.0,
	// 节点强度最大值上限（-1 表示无上限）
	"maxIntensity": -1.0,
	// 腐化生物每点节点强度增加的最大生命值（基础值）
	"healthBonusPerIntensity": 20.0,
	// 腐化生物每点节点强度增加的护甲值（基础值）
	"armorBonusPerIntensity": 1.0
}