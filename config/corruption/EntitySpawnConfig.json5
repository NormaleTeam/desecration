{
	// 是否阻止感染区域内的原版生物生成（true=阻止，false=允许原版生成与腐化生成并存）
	"preventVanillaSpawnInInfectedArea": true,
	// 每组生成规则列表，可添加任意数量
	"spawnGroups": [
		{
			// 生物注册名，例如：minecraft:zombie 或 modid:corrupted_zombie
			"entityId": "corruption:infection_zombie",
			// 每组生成间隔（刻），20刻=1秒
			"intervalTicks": 30,
			// 每组生成数量范围 [最小, 最大]
			"spawnCountRange": [
				1,
				3
			],
			// 生效群系列表，填写群系注册名，["all"] 代表所有群系
			"biomes": [
				"all"
			],
			// 生成位置：surface 地表 / underground 地下
			"spawnPosition": "surface",
			// 亮度区间 [最小亮度, 最大亮度]（使用方块光照等级 0-15）
			"lightLevelRange": [
				0,
				7
			],
			// 生效维度列表，填写维度注册名，["all"] 代表所有维度
			"dimensions": [
				"minecraft:overworld"
			],
			// 生效阶段区间 [最小阶段, 最大阶段]（叠加后总阶段）
			"phaseRange": [
				0,
				5
			],
			// 是否启用该生成规则
			"enabled": true,
			// 额外NBT数据（Json格式），例如 {"PersistenceRequired":1}
			"extraNbt": "{PersistenceRequired:1b}",
			// 生成点距离玩家的距离范围（XZ平面，方块）[最小距离, 最大距离]
			"spawnDistanceRange": [
				8,
				32
			],
			// 该类型生物在世界中最大同时存在数量（-1 表示无限制）
			"maxConcurrentSpawns": 8
